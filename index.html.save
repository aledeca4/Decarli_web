<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Esercizi</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0d0d;
      --surface: #161616;
      --border: #2a2a2a;
      --accent: #e8ff47;
      --accent2: #ff6b35;
      --text: #f0f0f0;
      --muted: #666;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Mono', monospace;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      overflow-x: hidden;
    }

    /* Noise texture overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      max-width: 700px;
      width: 100%;
    }

    header {
      margin-bottom: 3rem;
      border-left: 3px solid var(--accent);
      padding-left: 1.2rem;
    }

    header h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1;
      color: var(--text);
    }

    header h1 span {
      color: var(--accent);
    }

    header p {
      margin-top: 0.5rem;
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .group {
      margin-bottom: 2rem;
    }

    .group-label {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .group-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .btn-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.75rem;
    }

    .btn {
      position: relative;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: 'Space Mono', monospace;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      padding: 1rem 1.2rem;
      cursor: pointer;
      text-align: left;
      transition: all 0.18s ease;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      overflow: hidden;
    }

    .btn::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--accent);
      transition: width 0.25s ease;
    }

    .btn:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: #1a1a1a;
      transform: translateY(-2px);
    }

    .btn:hover::before {
      width: 100%;
    }

    .btn:active {
      transform: translateY(0);
    }

    .btn-arrow {
      font-size: 0.7rem;
      opacity: 0.4;
      transition: opacity 0.18s, transform 0.18s;
    }

    .btn:hover .btn-arrow {
      opacity: 1;
      transform: translateX(3px);
    }

    /* Group accent colors */
    .group-es03 .btn:hover { color: var(--accent); border-color: var(--accent); }
    .group-es03 .btn::before { background: var(--accent); }
    .group-es04 .btn:hover { color: var(--accent2); border-color: var(--accent2); }
    .group-es04 .btn::before { background: var(--accent2); }

    .group-es03 .group-label { color: #a8c200; }
    .group-es04 .group-label { color: #c24a1a; }

    footer {
      margin-top: 3rem;
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Eser<span>cizi</span></h1>
      <p>Seleziona un esercizio per aprirlo</p>
    </header>

    <!-- ES03 Group -->
    <div class="group group-es03">
      <div class="group-label">Serie 03</div>
      <div class="btn-grid">
        <a class="btn" href="https://w4s.filippobilardo.it/~decarli.alessandro/lavori/Decarli_web/lavori/es03a.html" target="_blank">
          ES03A <span class="btn-arrow">→</span>
        </a>
        <a class="btn" href="" target="_blank">
          ES03B <span class="btn-arrow">→</span>
        </a>
        <a class="btn" href="INSERISCI_LINK_ES03C" target="_blank">
          ES03C <span class="btn-arrow">→</span>
        </a>
        <a class="btn" href="INSERISCI_LINK_ES03D" target="_blank">
          ES03D <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>

    <!-- ES04 Group -->
    <div class="group group-es04">
      <div class="group-label">Serie 04</div>
      <div class="btn-grid">
        <a class="btn" href="INSERISCI_LINK_ES04A" target="_blank">
          ES04A <span class="btn-arrow">→</span>
        </a>
        <a class="btn" href="INSERISCI_LINK_ES04B" target="_blank">
          ES04B <span class="btn-arrow">→</span>
        </a>
        <a class="btn" href="INSERISCI_LINK_ES04C" target="_blank">
          ES04C <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>

    <footer>Sostituisci i placeholder "INSERISCI_LINK_..." con i tuoi URL</footer>
  </div>
</body>
</html>
